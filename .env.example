# =============================================================================
# Copy to `.env` and fill in. Do NOT commit `.env`.
# Values below are the defaults — uncomment and change anything you need.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production
PORT=3000
# Host to bind the HTTP server. Behind Nginx on the same VPS, keep 127.0.0.1
# so Node is not reachable from the public internet. Use 0.0.0.0 only if you
# intend to expose it directly (not recommended).
BIND_HOST=127.0.0.1

# How many reverse-proxy hops to trust for X-Forwarded-For / X-Forwarded-Proto.
# Nginx on same host:      1
# Cloudflare -> Nginx:     2
# No reverse proxy:        0
TRUST_PROXY=1

# Force `Secure` on the admin cookie even if NODE_ENV!=production.
# SECURE_COOKIES=true

# ---- Gmail (confirmation email) --------------------------------------------
# Create a 16-char App Password at https://myaccount.google.com/apppasswords
# (2-Step Verification must be enabled first)
GMAIL_USER=rmithanoitheatrclub@gmail.com
GMAIL_APP_PASSWORD=

MAIL_FROM_NAME=Theat.R - RMIT Hanoi Musical Theatre Club
# Set to "true" to skip sending email (useful for local dev)
DISABLE_EMAIL=false

# ---- Admin panel (/admin) ---------------------------------------------------
# Leave ADMIN_PASSWORD empty to DISABLE the admin panel entirely.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---- Storage ----------------------------------------------------------------
# Absolute paths let you put the DB on a persistent volume separate from the
# app code, so `git pull && npm ci` never touches real data.
# DB_PATH=/var/lib/theatre/theatre.db
# BANK_SCREENSHOT=/var/lib/theatre/bank-transfer.png
